# ─────────────────────────────────────────────────────────────────────────────
# Orbot agent — single-compose environment (COMPOSE SCOPE ONLY)
# Copy to `.env` and fill in. NEVER commit the real .env.
#
# This file only carries values docker-compose substitutes into the YAML
# (paths, ports, uid/gid, rclone). Real secrets — Discord token, OpenRouter
# key, allowed-user IDs — do NOT go here. Hermes loads those itself from
# bot_memory/orbot/.hermes/.env (see that file's .env.example).
# ─────────────────────────────────────────────────────────────────────────────

# Project / host identity ------------------------------------------------------
COMPOSE_PROJECT_NAME=orbot
TZ=America/Los_Angeles
# Host user that owns the bind-mounted dirs (bot_memory/, projects/, shared/).
# MUST match across host + containers so file edits don't fight over
# ownership, and matches the patched stage2-hook.sh (`id -u` / `id -g`).
PUID=1000
PGID=1000
HERMES_UID=1000
HERMES_GID=1000

# Hermes image / build ---------------------------------------------------------
AGENT_IMAGE=orbot-hermes:local

# Private wiki image / listener ------------------------------------------------
# The service binds on all host interfaces. Host firewall, reverse-proxy, and
# access-control policy are deployment responsibilities.
WIKI_SITE_IMAGE=orbot-wiki-site:local
WIKI_SITE_PORT=8120

# Hermes state + workspace (host paths bound into the container) --------------
# HERMES_HOME_DIR is HERMES_HOME (/opt/data): config.yaml, .env, SOUL.md,
# workspace, state.db all live here. Fill its own .env.example separately.
HERMES_HOME_DIR=./bot_memory/orbot/.hermes
# Local git repos / editable corpora exposed at /opt/projects:
PROJECTS_DIR=./projects

# ─────────────────────────────────────────────────────────────────────────────
# rclone / Google Drive mount
# ─────────────────────────────────────────────────────────────────────────────
# Name of the remote inside rclone.conf (the [section] header).
RCLONE_REMOTE=gdrive_hiorbit
# Host path that becomes the FUSE mount point. Hermes binds this in too, at
# /opt/gdrive_hiorbit. Keep it OUTSIDE the HERMES_HOME bind (nested FUSE binds
# silently fail — see the compose comments / ../agent-access-recipe.md §4d).
GDRIVE_MOUNT_DIR=./shared/gdrive_hiorbit
# WebGUI auth + port. CHANGE these for any non-Tailscale / internet-exposed host.
RCLONE_USER=admin
RCLONE_PASSWORD=admin
RCLONE_GUI_PORT=5575
# VFS cache cap for streamed PDFs/images.
RCLONE_CACHE_SIZE=10G

# rclone.conf itself (with the Google OAuth token) is NOT an env var — it lives
# at ./rclone/config/rclone.conf. Generate it with:  rclone authorize "drive"

# ─────────────────────────────────────────────────────────────────────────────
# Tailscale exposure (dashboard + gateway API server)
# ─────────────────────────────────────────────────────────────────────────────
# The host's Tailscale IP. Get it with: tailscale ip -4
# Both the dashboard and the gateway's optional API server bind to THIS
# address specifically (not 0.0.0.0) — under network_mode: host, 0.0.0.0
# would also expose them on any LAN/public interface on the box. Leave unset
# to fall back to the upstream-safe 127.0.0.1 (loopback only, no Tailscale
# access).
TAILSCALE_IP=<TAILSCALE_IP>   # e.g. 100.85.188.20 — run `tailscale ip -4` to get yours

# API_SERVER_KEY is a genuine secret (bearer token for Hermes's optional
# OpenAI-compatible API server) but lives here, not in the Hermes runtime
# .env — Docker passes it straight through as a container env var, matching
# upstream's own compose pattern, rather than Hermes loading it via
# load_dotenv. Required the moment the gateway's API_SERVER_HOST is set;
# compose will refuse to start gateway without it. Generate with:
#   openssl rand -hex 24
API_SERVER_KEY=
