# =============================================================================
# Deployment v0 — consolidated environment intake (Hermes Agent / HTF_Social)
# =============================================================================
# Copy to a REAL, UNCOMMITTED .env and fill every <PLACEHOLDER>. Never commit a
# filled-in copy. Pair with preflight-questionnaire.md.
#
# IMPORTANT — there are TWO env scopes; values below are tagged:
#   [runtime]  → goes in  bot_memory/agent5/.hermes/.env   (Hermes reads at runtime)
#   [compose]  → goes in  hermes-agent/.env                (docker compose substitution)
#   [config]   → NOT read from .env; copied into config.yaml during deploy (kept
#                here so this file is the single intake surface)
#   [rclone]   → optional; configure rclone via these env vars OR `rclone config`
# =============================================================================

# ----- Discord (agent runtime) ----------------------------------------------
# [runtime] Bot token for THIS bot. One token = one active gateway session.
DISCORD_BOT_TOKEN=<DISCORD_BOT_TOKEN>

# [runtime] User access. false + DISCORD_ALLOWED_USERS to restrict; true = anyone
# in the allowed channels (or via DM) can drive the agent.
DISCORD_ALLOW_ALL_USERS=false
DISCORD_ALLOWED_USERS=<DISCORD_USER_ID_1>,<DISCORD_USER_ID_2>

# [runtime] Home channel for cron output / proactive messages.
DISCORD_HOME_CHANNEL=<DISCORD_HOME_CHANNEL_ID>
DISCORD_HOME_CHANNEL_THREAD_ID=<DISCORD_HOME_CHANNEL_ID>

# [config] Server (guild) ID — for the invite link + slash-command scoping.
DISCORD_SERVER_ID=<DISCORD_SERVER_ID>

# [config] → config.yaml discord.allowed_channels. Comma-separated channel IDs the
# bot responds in. Leave empty to allow every visible channel (not recommended).
DISCORD_ALLOWED_CHANNELS=<DISCORD_CHANNEL_ID_1>,<DISCORD_CHANNEL_ID_2>

# ----- Model backend (OpenRouter, direct) ------------------------------------
# Direct connection to OpenRouter (OpenAI-compatible). No local proxy.
# [runtime] OpenRouter API key (Hermes custom provider reads OPENAI_API_KEY).
OPENAI_API_KEY=<OPENROUTER_API_KEY>

# [config] → config.yaml model.base_url
MODEL_BASE_URL=https://openrouter.ai/api/v1

# [config] → config.yaml model.default — an OpenRouter model id (e.g.
# "anthropic/claude-sonnet-4.6", "deepseek/deepseek-chat").
MODEL_DEFAULT=<OPENROUTER_MODEL_ID>

# [optional] OpenRouter attribution headers (set if you want app ranking/limits).
# OPENROUTER_HTTP_REFERER=<YOUR_APP_URL>
# OPENROUTER_X_TITLE=<YOUR_APP_NAME>

# [rag] Embeddings provider — OpenRouter is chat-focused, so embeddings may need a
# SEPARATE endpoint. Leave blank to fall back to OPENAI_API_KEY/MODEL_BASE_URL.
# Confirm against the team's rag-mcp system.
# EMBEDDING_API_KEY=<EMBEDDING_API_KEY>
# EMBEDDING_BASE_URL=<EMBEDDING_BASE_URL>

# ----- Host / container (compose substitution) -------------------------------
# [compose] Match the host user that owns bot_memory/agent5 (`id -u` / `id -g`).
HERMES_UID=1000
HERMES_GID=1000

# ----- Google Drive via rclone (OPTIONAL) ------------------------------------
# [rclone] Configure a remote either with `rclone config` OR these env vars.
# Replace REMOTE with your remote name (e.g. KST). Service-account path is preferred
# for unattended agents; share the target folder with the SA email.
# RCLONE_CONFIG_REMOTE_TYPE=drive
# RCLONE_CONFIG_REMOTE_SCOPE=drive.readonly
# RCLONE_CONFIG_REMOTE_SERVICE_ACCOUNT_FILE=<PATH_TO_SA_JSON>   # in secrets store
# RCLONE_CONFIG_REMOTE_ROOT_FOLDER_ID=<GDRIVE_FOLDER_ID>
# RCLONE_CONFIG_REMOTE_TEAM_DRIVE=<SHARED_DRIVE_ID>             # if a Shared Drive
# Mount: rclone mount REMOTE: <CODE_ROOT>/shared/gdrive_kst --vfs-cache-mode=writes --daemon

# ----- Optional gateways / API server (compose substitution) -----------------
# [compose] OpenAI-compatible API server (off unless BOTH set; auth mandatory).
# API_SERVER_HOST=127.0.0.1
# API_SERVER_KEY=<API_SERVER_KEY>

# [compose] Microsoft Teams (dev.botframework.com).
# TEAMS_CLIENT_ID=<TEAMS_CLIENT_ID>
# TEAMS_CLIENT_SECRET=<TEAMS_CLIENT_SECRET>
# TEAMS_TENANT_ID=<TEAMS_TENANT_ID>
# TEAMS_ALLOWED_USERS=<TEAMS_USER_ID_1>,<TEAMS_USER_ID_2>

# [compose] Google Chat.
# GOOGLE_CHAT_PROJECT_ID=<GCHAT_PROJECT_ID>
# GOOGLE_CHAT_SUBSCRIPTION_NAME=<GCHAT_SUBSCRIPTION>
# GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=<PATH_TO_GCHAT_SA_JSON>
# GOOGLE_CHAT_ALLOWED_USERS=<GCHAT_USER_ID_1>,<GCHAT_USER_ID_2>
